# Copy this file to .env to customize your Docker setup

# ====================================
# Docker Compose Environment Variables
# ====================================

APP_IMAGE=

# Next JS APP
APP_PORT=3000

# PostgreSQL Configuration
POSTGRES_VERSION=latest
POSTGRES_CONTAINER_NAME=cameroonmemoria-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cameroonmemoria

# PgAdmin Configuration
PGADMIN_VERSION=latest
PGADMIN_CONTAINER_NAME=cameroonmemoria-pgadmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@cameroonmemoria.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_CONFIG_SERVER_MODE=False

# Minio Configuration
MINIO_VERSION=latest
MINIO_CONTAINER_NAME=cameroonmemoria-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=cameroonmemoria-media

# =================================
# Runtime app Environment Variables
# =================================
# Better Auth
BETTER_AUTH_SECRET=XSIGKiFU9CUhnEvnRG1Y2oykhvbWo81D
BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@africamemoria.com
ADMIN_NAME=Adminatreur annonce
ADMIN_PASSWORD=asdaRe11naA

# Email Configuration (for password reset, notifications, etc.)
# Options: console (development), smtp (production), resend, sendgrid
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cameroonmemoria.com
SMTP_FROM_NAME=Cameroon Memoria

# Configuration de la base de données PostgreSQL
DATABASE_URL=

# Configuration MinIO (stockage d'objets)
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_USE_SSL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_PUBLIC_URL=

# Configuration des APIs de paiement
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# URLs de l'application
NEXT_PUBLIC_APP_URL=
